# Copy to `backend/.env` and fill secrets. Never commit `.env`.
# Used for: local uvicorn/arq/alembic AND Docker Compose
#   (`docker compose --env-file backend/.env up -d --build`).

# --- Compose / reverse proxy ---
# Local HTTP: :80
# Production auto-HTTPS: your.domain.com
SITE_ADDRESS=:80
POSTGRES_PASSWORD=
ENVIRONMENT=production

# --- Application ---
APP_NAME=SlideLens
APP_DESCRIPTION=AI deck review API
APP_VERSION=0.1.0
# Compose overrides DB_HOST=db for app/worker; local non-Docker uses localhost:
DB_HOST=localhost
DB_PORT=5432
DB_NAME=slidelens
DB_USER=slidelens
DB_PASSWORD=
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=
# Leave empty / unset ENABLE_DOCS to auto-disable OpenAPI in production
# ENABLE_DOCS=true
# Empty behind Caddy (same origin). For host Vite (`npm run dev`): http://localhost:5173
CORS_ALLOW_ORIGINS=

# Auth / JWT
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
FILE_SIGNATURE_EXPIRE_MINUTES=15
# Same-origin via Caddy. Host Vite: PUBLIC_* → :8000 / :5173 and set CORS above.
PUBLIC_API_URL=http://localhost
PUBLIC_APP_URL=http://localhost
# Comma-separated emails that get is_admin (unlimited reviews)
# ADMIN_EMAILS=admin@demo.com

# LLM / VLM (OpenAI-compatible API; keys stay on the server only)
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_FULL=gpt-4o
LLM_MODEL_SCREENING=
LLM_MODEL_TRANSCRIPTION=whisper-1
LLM_TIMEOUT_SECONDS=120
LLM_MAX_ZOOMS_PER_SLIDE=3

# Storage / privacy
STORAGE_ROOT=./storage
FILE_EXPIRE_DAYS=7
# Baked SPA path inside the image (compose sets this for app)
STATIC_DIR=/app/static

# Cost alert threshold (RUB per review) — optional, default 150
# REVIEW_COST_ALERT_RUB=150.0

# Optional (empty = disabled; all have code paths when set):
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com
# SENTRY_DSN=
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@example.com
